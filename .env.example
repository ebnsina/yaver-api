# Yaver API — required environment. Copy to .env for local dev (.env is gitignored).
# All vars are required; the app fails to boot if any is missing (no hardcoded defaults).

YAVER_ENV=dev
YAVER_PORT=8080

# Postgres DSN (matches docker-compose).
YAVER_DATABASE_URL=postgres://yaver:yaver@localhost:5432/yaver?sslmode=disable

# HMAC key for hashing OTP codes at rest. Use a long random value in prod.
YAVER_AUTH_SECRET=dev-only-change-me-to-a-32-byte-random-secret

# Orchestrator: "local" (in-process, no deps) or "hatchet" (self-hosted engine).
# For hatchet, also export HATCHET_CLIENT_TOKEN and HATCHET_CLIENT_TLS_STRATEGY=none.
YAVER_ORCHESTRATOR=local

# Telephony: "mock" (dev, no telco) or "livekit" (dial out via a LiveKit SIP
# outbound trunk / BD carrier). LiveKit creds are required only for "livekit".
YAVER_VOICE_PROVIDER=mock
# YAVER_LIVEKIT_URL=wss://your-project.livekit.cloud
# YAVER_LIVEKIT_API_KEY=
# YAVER_LIVEKIT_API_SECRET=
# YAVER_LIVEKIT_SIP_TRUNK_ID=ST_...

# AES-256-GCM master key (base64 of 32 bytes) for secrets at rest.
# Generate: openssl rand -base64 32
YAVER_ENCRYPTION_KEY=

# Observability (OpenTelemetry, opt-in). Tracing activates only when an OTLP
# endpoint is set; all knobs use the standard OTEL_* env vars.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=yaver-api

# Chat AI provider (provider-agnostic). "builtin" is the dependency-free
# rule-based assistant; "anthropic" uses Claude via the official SDK.
YAVER_CHAT_PROVIDER=builtin
# Required only when YAVER_CHAT_PROVIDER=anthropic. Model is optional and
# defaults to claude-opus-4-8.
# YAVER_ANTHROPIC_API_KEY=sk-ant-...
# YAVER_ANTHROPIC_MODEL=claude-opus-4-8

# OTP delivery over SMS: "log" (dev, prints the code to the logs) or "twilio".
# Twilio creds are required only for "twilio".
YAVER_SMS_SENDER=log
# YAVER_TWILIO_ACCOUNT_SID=AC...
# YAVER_TWILIO_AUTH_TOKEN=
# YAVER_TWILIO_FROM=+1...

# Messaging (WhatsApp/Messenger) delivery: "log" (dev, records outbound) or
# "meta" (first-party Graph API). "meta" uses each connection's stored token.
YAVER_MSG_SENDER=log

# Credit top-up gateway: "mock" (dev, no real money) or "sslcommerz" (aggregates
# cards + bKash/Nagad/Rocket). YAVER_APP_URL is the public base URL the gateway
# redirects/IPNs back to. SSLCommerz store creds are required only for that gateway.
YAVER_PAYMENT_GATEWAY=mock
YAVER_APP_URL=http://localhost:8080
# Dashboard base URL the customer is sent back to after paying.
YAVER_WEB_URL=http://localhost:5173
# YAVER_SSLCOMMERZ_STORE_ID=
# YAVER_SSLCOMMERZ_STORE_PASSWD=
# YAVER_SSLCOMMERZ_SANDBOX=true

# Transactional email: "log" (dev, records to the logger) or "resend" (Resend API).
# YAVER_RESEND_API_KEY is required only when YAVER_EMAIL_SENDER=resend.
YAVER_EMAIL_SENDER=log
YAVER_EMAIL_FROM=Yaver <noreply@yaver.app>
# YAVER_RESEND_API_KEY=re_...
